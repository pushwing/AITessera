# 앱
APP_ENV=local
APP_DEBUG=true
APP_BASE_URL=http://localhost:9300/

# DB (PDO / MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=aitessera
DB_USER=aitessera
DB_PASS=

# Redis (캐시 · 큐)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT (필수 — 32자 이상 랜덤 문자열, HS256 기준)
JWT_SECRET=change_me_to_a_random_string_at_least_32_chars
JWT_ALGO=HS256
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600
