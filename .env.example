# 앱
APP_ENV=local
APP_DEBUG=true
APP_BASE_URL=http://localhost:9300/

# DB (PDO / MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=aitessera
DB_USER=aitessera
DB_PASS=

# Redis (캐시 · 큐)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT
# 서명 알고리즘: HS256(대칭키) 또는 RS256(비대칭키)
JWT_ALGO=HS256

# HS256 사용 시 필수 — 32자 이상 랜덤 문자열
JWT_SECRET=change_me_to_a_random_string_at_least_32_chars

# RS256 사용 시 필수 — 개인키로 서명, 공개키로 검증.
# 키페어 생성: php bin/console jwt:keygen  (기본 var/keys/ 에 생성)
# 운영 개인키는 커밋 금지 · SSM Parameter Store / Secrets Manager 로 배치 권장.
# JWT_PRIVATE_KEY_PATH=var/keys/jwt_private.pem
# JWT_PUBLIC_KEY_PATH=var/keys/jwt_public.pem
# 개인키에 암호가 걸려 있으면 설정 (없으면 비워둠)
# JWT_PRIVATE_KEY_PASSPHRASE=

JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# 이메일 인증 토큰 TTL (초 단위, 기본 24시간)
EMAIL_VERIFY_TTL=86400

# 레이트 리밋 (1분당 허용 요청 수)
RATE_LIMIT_AUTH=10    # 인증 엔드포인트(로그인·가입 등) — 엄격
RATE_LIMIT_API=120    # 일반 API
