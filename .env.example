# 앱
APP_ENV=local
APP_DEBUG=true
APP_BASE_URL=http://localhost:9300/

# DB (PDO / MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=aitessera
DB_USER=aitessera
DB_PASS=

# Redis (캐시 · 큐)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT
# 서명 알고리즘: HS256(대칭키) 또는 RS256(비대칭키)
JWT_ALGO=HS256

# HS256 사용 시 필수 — 32자 이상 랜덤 문자열
JWT_SECRET=change_me_to_a_random_string_at_least_32_chars

# RS256 사용 시 필수 — 개인키로 서명, 공개키로 검증.
# 키페어 생성: php bin/console jwt:keygen  (기본 var/keys/ 에 생성)
# 운영 개인키는 커밋 금지 · SSM Parameter Store / Secrets Manager 로 배치 권장.
# JWT_PRIVATE_KEY_PATH=var/keys/jwt_private.pem
# JWT_PUBLIC_KEY_PATH=var/keys/jwt_public.pem
# 개인키에 암호가 걸려 있으면 설정 (없으면 비워둠)
# JWT_PRIVATE_KEY_PASSPHRASE=

JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# 이메일 인증 토큰 TTL (초 단위, 기본 24시간)
EMAIL_VERIFY_TTL=86400

# 레이트 리밋 (1분당 허용 요청 수)
RATE_LIMIT_AUTH=10    # 인증 엔드포인트(로그인·가입 등) — 엄격
RATE_LIMIT_API=120    # 일반 API

# AI 로그 분류 (Claude API) — error/critical 로그를 자동 분류·요약한다.
# 키를 비워두면(기본) AI 분류를 건너뛰고 로그는 그대로 저장된다(graceful degradation).
# 운영 시크릿은 커밋 금지 · SSM Parameter Store / Secrets Manager 로 배치 권장.
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001   # 분류용 저비용·고속 모델
# AI_TIMEOUT=5                                # 외부 호출 타임아웃(초)

# 일일 로그 리포트 (report:daily) — 전일 로그를 집계·요약해 담당자에게 메일 발송한다.
# 수신자를 비워두면(기본) 리포트 워커가 발송을 건너뛴다. cron/systemd timer 로 하루 1회 실행.
# LOG_REPORT_RECIPIENT=ops@example.com
