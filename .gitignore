# 의존성
/vendor/

# 환경변수 · 시크릿 (절대 커밋 금지)
.env
.env.testing
.env.*.local

# JWT 서명 키 (RS256 개인/공개키 — 절대 커밋 금지)
/var/keys/
*.pem

# 런타임 산출물 (var/) — 디렉토리 구조는 .gitkeep 로 유지, 내용은 커밋 금지
/var/cache/*
!/var/cache/.gitkeep
/var/logs/*.log
/var/logs/raw/*
!/var/logs/raw/.gitkeep
/var/logs/queue-failed/*
!/var/logs/queue-failed/.gitkeep

# 툴 캐시
.php-cs-fixer.cache
.phpunit.cache/
.phpunit.result.cache

# superpowers subagent-driven-development 진행 로그(세션 스크래치)
/.superpowers/

# OS · 에디터
.DS_Store

# 레거시 (참고용 — 깃 추가 금지)
/lagacy-source/
